# Copy to .env and fill in values.

# MongoDB (required) — local example or paste MongoDB Atlas SRV connection string
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=inkspire_shop

# Auth (required for login/register tokens)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

PORT=3000

# --- AI chat assistant (InkSpire widget) — set at least one for natural-language replies ---
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional; default is gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-flash

# OpenAI alternative (used if Gemini is unset, or as fallback if Gemini fails)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Prefer which provider when both keys exist: auto | gemini | openai
# AI_PROVIDER=auto
